# ─────────────────────────────────────────────────────────────
#  Whisper Persian v4 — STT Service Configuration
#  کپی کنید:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ══════════════════════════════════════════════════════════════
#  مدل و زبان
# ══════════════════════════════════════════════════════════════

# نام مدل HuggingFace (اگه عوض نکنی همون whisper-persian-v4 استفاده میشه)
# DEFAULT: nezamisafa/whisper-persian-v4
STT_MODEL=nezamisafa/whisper-persian-v4

# زبان پیش‌فرض ترنسکریپشن
# DEFAULT: fa
STT_LANGUAGE=fa

# دستگاه: cpu یا cuda (اگه GPU داری)
# DEFAULT: cpu
DEVICE=cpu

# ══════════════════════════════════════════════════════════════
#  محدودیت‌ها و عملکرد
# ══════════════════════════════════════════════════════════════

# حداکثر اندازه فایل آپلودی (مگابایت)
# DEFAULT: 100
MAX_FILE_SIZE_MB=100

# حداکثر درخواست‌های همزمان (بیشتر = RAM بیشتر)
# برای CPU با 8GB RAM: 2 مناسبه
# DEFAULT: 2
MAX_CONCURRENT=2

# تایم‌اوت هر درخواست (ثانیه) — فایل‌های بلند بیشتر طول می‌کشن
# DEFAULT: 600 (10 دقیقه)
REQUEST_TIMEOUT=600

# ══════════════════════════════════════════════════════════════
#  سرور
# ══════════════════════════════════════════════════════════════

# پورت سرویس
# DEFAULT: 8000
PORT=8000

# سطح لاگ: DEBUG, INFO, WARNING, ERROR
# DEFAULT: INFO
LOG_LEVEL=INFO
